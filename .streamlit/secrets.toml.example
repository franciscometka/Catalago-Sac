# Renomeie este arquivo para secrets.toml e preencha com a connection string do Supabase.
# Em Project Settings > Database > Connection string (URI) no painel do Supabase.
# Use a porta 6543 (Connection Pooler / Transaction) para apps serverless,
# ou 5432 (Direct connection) para uso local.

[connections]
database_url = "postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres"
